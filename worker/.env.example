# WORKER (LOCAL) — contém segredos. Mantenha fora do git. NÃO vai para o Netlify.
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-SECRETA   # só aqui, nunca no front
OWNER_USER_ID=uuid-do-seu-usuario-supabase           # filtra jobs do dono

WORKER_ID=pc-rodrigo
WORK_DIR=C:/Users/Rodrigo Paiva/atelier-work          # pasta de trabalho dos livros
POLL_INTERVAL_MS=5000
HEARTBEAT_STALE_MIN=15                                 # jobs running órfãos voltam à fila
MAX_PARALLEL_HEAVY=1                                   # jobs pesados em série (FASE 1+)

# Claude Code (plano MAX, já logado nesta máquina) — usado a partir da FASE 1.
# WINDOWS: o worker usa spawn(shell:false), que NÃO resolve shims .cmd nem nomes no PATH.
# Aponte para o EXECUTÁVEL real (.exe). Ex.:
#   CLAUDE_BIN=C:/Users/<voce>/AppData/Roaming/npm/node_modules/@anthropic-ai/claude-code/bin/claude.exe
#   PY_BIN=C:/Users/<voce>/AppData/Local/Programs/Python/Python312/python.exe
# Em Linux/macOS, "claude" e "python3" no PATH funcionam.
CLAUDE_BIN=claude
# Caminho do runner da skill livro-do-zero-ao-epub (assets/livro_runner.py).
RUNNER_PATH=C:/Users/<voce>/.claude/skills/livro-do-zero-ao-epub/assets/livro_runner.py
PY_BIN=python
MODEL=opus
